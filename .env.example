# Session timeout in milliseconds (default: 30 minutes)
VITE_SESSION_TIMEOUT_MS=1800000

# Maximum login attempts before account lockout (default: 3)
VITE_MAX_LOGIN_ATTEMPTS=3

# Lockout duration in milliseconds after max login attempts exceeded (default: 30 minutes)
VITE_LOCKOUT_DURATION_MS=1800000

# Token expiry in hours (default: 24)
VITE_TOKEN_EXPIRY_HOURS=24

# Maximum card unlock attempts per day (default: 3)
VITE_MAX_UNLOCK_ATTEMPTS_PER_DAY=3

# Maximum PIN resend attempts per day (default: 3)
VITE_MAX_RESEND_ATTEMPTS_PER_DAY=3

# Base URL for backend API (for future backend integration)
VITE_API_BASE_URL=http://localhost:8080/api